{
  "name": "@scalang/cli",
  "version": "0.0.8",
  "description": "CLI for generating multilingual OpenAPI documentation with Scalang using Lingo.dev and Scalar",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Code-Parth/scalang.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Code-Parth/scalang/tree/main/packages/cli#readme",
  "keywords": [
    "scalang",
    "cli",
    "openapi",
    "i18n",
    "translation",
    "scalar",
    "lingo",
    "lingo.dev"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "scalang": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "prebuild": "rm -rf template && rsync -a --exclude='node_modules' --exclude='.next' --exclude='.turbo' --exclude='tsconfig.tsbuildinfo' --exclude='.env.local' ../../apps/template/ template/",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix && prettier --write ."
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@inquirer/prompts": "^8.3.0",
    "@lingo.dev/_locales": "^0.3.3",
    "@lingo.dev/_spec": "^0.49.0",
    "@scalar/openapi-parser": "^0.25.1",
    "ajv": "^8.17.1",
    "commander": "^14.0.0",
    "lingo.dev": "^0.133.1",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@scalang/eslint-config": "*",
    "@scalang/checksum": "*",
    "@scalang/lingo": "*",
    "@scalang/schema": "*",
    "@scalang/spec-loader": "*",
    "@scalang/typescript-config": "*",
    "@scalang/validate": "*",
    "eslint": "^9.39.1",
    "@types/node": "^22.15.3",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  }
}
