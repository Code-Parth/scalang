{
  "name": "@scalang/react",
  "version": "0.0.3",
  "description": "React components for Scalang multilingual API documentation powered by Scalar",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Code-Parth/scalang.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Code-Parth/scalang/tree/main/packages/react#readme",
  "keywords": [
    "scalang",
    "react",
    "openapi",
    "scalar",
    "api-reference",
    "i18n"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./style.css"
  },
  "files": [
    "dist",
    "style.css"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix && prettier --write ."
  },
  "dependencies": {
    "@scalar/api-reference-react": "^0.9.0"
  },
  "devDependencies": {
    "@scalang/eslint-config": "*",
    "@scalang/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.1",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}
