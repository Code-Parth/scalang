{
  "name": "scalang",
  "private": true,
  "scripts": {
    "clean": "rm -rf node_modules .turbo apps/*/node_modules apps/*/.turbo packages/*/node_modules packages/*/.turbo",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix && prettier --write .",
    "typecheck": "turbo run typecheck",
    "test": "bun test tests/",
    "test:integration": "bun test tests/"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "bun-types": "latest",
    "prettier": "^3.7.4",
    "turbo": "^2.8.15",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
