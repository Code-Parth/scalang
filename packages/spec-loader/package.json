{
  "name": "@scalang/spec-loader",
  "version": "0.0.2",
  "description": "OpenAPI spec parser, field extractor, and translation injector for Scalang using Scalar OpenAPI parser",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Code-Parth/scalang.git",
    "directory": "packages/spec-loader"
  },
  "homepage": "https://github.com/Code-Parth/scalang/tree/main/packages/spec-loader#readme",
  "keywords": [
    "scalang",
    "openapi",
    "spec-loader",
    "parser",
    "scalar"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix && prettier --write ."
  },
  "dependencies": {
    "@scalar/openapi-parser": "^0.25.1",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@scalang/eslint-config": "*",
    "@scalang/typescript-config": "*",
    "eslint": "^9.39.1",
    "@scalang/schema": "*",
    "@types/node": "^22.15.3",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  }
}
