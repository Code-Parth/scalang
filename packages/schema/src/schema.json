    },
    "translatableFieldGroup": {
      "type": "object",
      "required": ["name", "enabled", "fields"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Group identifier (e.g. info, tags, operations)"
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether this group is enabled for translation"
        },
        "fields": {
          "type": "array",
          "items": { "type": "string" },
          "description": "JSONPath-like field paths (e.g. info.title, paths.*.*.summary)"
        }
      },
      "additionalProperties": false
    }
  }
}
