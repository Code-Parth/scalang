{
  "name": "@scalang/schema",
  "version": "0.0.4",
  "description": "Configuration schema, types, and validation for Scalang with Lingo.dev and Scalar support",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Code-Parth/scalang.git",
    "directory": "packages/schema"
  },
  "homepage": "https://github.com/Code-Parth/scalang/tree/main/packages/schema#readme",
  "keywords": [
    "scalang",
    "openapi",
    "schema",
    "i18n",
    "translation",
    "scalar",
    "lingo",
    "lingo.dev"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema.json": "./schema/scalang-config.schema.json"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "bun test ../../tests"
  },
  "dependencies": {
    "@lingo.dev/_locales": "^0.3.3",
    "@lingo.dev/_spec": "^0.49.0",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@scalang/eslint-config": "*",
    "@scalang/typescript-config": "*",
    "@scalar/api-reference-react": "^0.9.3",
    "@scalar/types": "^0.7.1",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
